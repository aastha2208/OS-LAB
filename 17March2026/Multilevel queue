#include <stdio.h>

struct process
{
    int pid, at, bt, rt, ct, wt, tat, start, queue, completed;
};

int main()
{
    int n, tq, time = 0, done;
    float avgwt = 0, avgtat = 0, avgrt = 0, avgct = 0;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    struct process p[n];

    for (int i = 0; i < n; i++)
    {
        p[i].pid = i + 1;
        printf("\nProcess %d\n", i + 1);
        printf("Enter Arrival Time and Burst Time: ");
        scanf("%d %d", &p[i].at, &p[i].bt);
        printf("Enter Queue (1: RR, 2: FCFS): ");
        scanf("%d", &p[i].queue);
        p[i].rt = p[i].bt;
        p[i].completed = 0;
        p[i].start = -1;
    }

    printf("Enter Time Quantum: ");
    scanf("%d", &tq);

    do
    {
        done = 1;
        for (int i = 0; i < n; i++)
        {
            if (p[i].queue == 1 && p[i].rt > 0 && p[i].at <= time)
            {
                done = 0;

                if (p[i].start == -1)
                    p[i].start = time;

                if (p[i].rt > tq)
                {
                    time += tq;
                    p[i].rt -= tq;
                }
                else
                {
                    time += p[i].rt;
                    p[i].rt = 0;
                    p[i].ct = time;
                    p[i].completed = 1;
                }
            }
        }
    } while (!done);

    for (int i = 0; i < n; i++)
    {
        if (p[i].queue == 2)
        {
            if (time < p[i].at)
                time = p[i].at;

            p[i].start = time;
            time += p[i].bt;
            p[i].ct = time;
            p[i].rt = 0;
        }
    }

    for (int i = 0; i < n; i++)
    {
        p[i].tat = p[i].ct - p[i].at;
        p[i].wt = p[i].tat - p[i].bt;
        int rt = p[i].start - p[i].at;

        avgwt += p[i].wt;
        avgtat += p[i].tat;
        avgrt += rt;
        avgct += p[i].ct;
    }

    printf("\nPID\tAT\tBT\tCT\tTAT\tWT\tRT\n");

    for (int i = 0; i < n; i++)
    {
        int rt = p[i].start - p[i].at;
        printf("%d\t%d\t%d\t%d\t%d\t%d\t%d\n",
               p[i].pid, p[i].at, p[i].bt,
               p[i].ct, p[i].tat, p[i].wt, rt);
    }

    printf("\nAverage CT = %.2f", avgct / n);
    printf("\nAverage TAT = %.2f", avgtat / n);
    printf("\nAverage WT = %.2f", avgwt / n);
    printf("\nAverage RT = %.2f\n", avgrt / n);

    return 0;
}
